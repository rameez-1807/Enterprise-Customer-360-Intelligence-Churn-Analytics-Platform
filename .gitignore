# =============================================================================
# Enterprise Customer 360 Intelligence & Churn Analytics Platform
# Git Ignore Rules
# =============================================================================

# ---------------------------------------------------------------------------
# Python Runtime Artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------------------------
# IDE & Editor Configurations
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
*.env.local

# ---------------------------------------------------------------------------
# Processed Data & Model Outputs (Generated Artifacts)
# ---------------------------------------------------------------------------
data/processed/*
data/outputs/*
!data/processed/.gitkeep
!data/outputs/.gitkeep
!data/outputs/models/
!data/outputs/models/best_model.joblib
!data/outputs/models/model_metadata.json

# ---------------------------------------------------------------------------
# Log Files
# ---------------------------------------------------------------------------
logs/*.log
logs/*.json

# ---------------------------------------------------------------------------
# Jupyter Notebook Checkpoints
# ---------------------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# OS-Level Metadata
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Testing & Coverage Artifacts
# ---------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# Streamlit Cache
# ---------------------------------------------------------------------------
.streamlit/
