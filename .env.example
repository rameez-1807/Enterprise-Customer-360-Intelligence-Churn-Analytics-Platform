# =============================================================================
# Enterprise Customer 360 Intelligence & Churn Analytics Platform
# Environment Configuration Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to `.env` in the project root.
#   2. Modify values as needed for your local development environment.
#   3. NEVER commit the `.env` file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application Environment
# ---------------------------------------------------------------------------
# Options: DEV | STAGING | PROD
APP_ENV=DEV

# ---------------------------------------------------------------------------
# Logging Configuration
# ---------------------------------------------------------------------------
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs

# ---------------------------------------------------------------------------
# Data Paths
# ---------------------------------------------------------------------------
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
OUTPUT_DATA_DIR=data/outputs
RAW_DATASET_FILENAME=E Commerce Dataset.xlsx

# ---------------------------------------------------------------------------
# Model Artifacts
# ---------------------------------------------------------------------------
MODEL_ARTIFACTS_DIR=data/outputs/models
MODEL_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Dashboard Configuration
# ---------------------------------------------------------------------------
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501
DASHBOARD_THEME=dark
DASHBOARD_DEBUG=true

# ---------------------------------------------------------------------------
# Performance Tuning
# ---------------------------------------------------------------------------
ENABLE_DATA_CACHING=true
MAX_MEMORY_MB=4096
